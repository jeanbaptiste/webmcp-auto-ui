{
  "name": "@webmcp-auto-ui/ui",
  "version": "2.5.29",
  "description": "Svelte 5 UI components — primitives, widgets, window manager",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "svelte": "./src/index.ts",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tailwind.preset": "./tailwind.preset.js",
    "./canvas": {
      "svelte": "./src/stores/canvas.svelte.ts",
      "import": "./src/stores/canvas.svelte.ts"
    },
    "./widgets/notebook/*": {
      "svelte": "./src/widgets/notebook/*",
      "import": "./src/widgets/notebook/*"
    },
    "./widgets/notebook/recipes/*": "./src/widgets/notebook/recipes/*"
  },
  "scripts": {
    "build": "svelte-package -i src",
    "dev": "svelte-package -w -i src",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "d3": "^7.9.0",
    "leaflet": ">=1.9.0",
    "svelte": "^5.0.0",
    "vega-embed": "^6.24.0"
  },
  "peerDependenciesMeta": {
    "vega-embed": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "@types/leaflet": "^1.9.0",
    "leaflet": "^1.9.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "webmcp",
    "svelte",
    "ui",
    "widgets",
    "auto-ui"
  ],
  "dependencies": {
    "@types/d3": "^7.4.3",
    "@webmcp-auto-ui/core": "*",
    "@webmcp-auto-ui/sdk": "*",
    "bits-ui": "^2.17.2",
    "clsx": "^2.1.1",
    "highlight.js": "^11.10.0",
    "html-to-image": "^1.11.13",
    "marked": "^14.1.3",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "turndown": "^7.2.4"
  }
}
