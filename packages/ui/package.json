{
  "name": "@webmcp-auto-ui/ui",
  "version": "2.5.3",
  "description": "Svelte 5 UI components — primitives, widgets, window manager",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "svelte": "./src/index.ts",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tailwind.preset": "./tailwind.preset.js",
    "./canvas": {
      "svelte": "./src/stores/canvas.svelte.ts",
      "import": "./src/stores/canvas.svelte.ts"
    }
  },
  "scripts": {
    "build": "svelte-package -i src",
    "dev": "svelte-package -w -i src",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "d3": "^7.9.0",
    "leaflet": ">=1.9.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "@types/leaflet": "^1.9.0",
    "leaflet": "^1.9.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "webmcp",
    "svelte",
    "ui",
    "widgets",
    "auto-ui"
  ],
  "dependencies": {
    "@webmcp-auto-ui/sdk": "*",
    "@types/d3": "^7.4.3",
    "bits-ui": "^2.17.2",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  }
}
