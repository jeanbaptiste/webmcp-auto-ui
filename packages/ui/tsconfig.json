{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@webmcp-auto-ui/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
