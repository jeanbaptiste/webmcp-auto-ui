{
  "name": "@webmcp-auto-ui/sdk",
  "version": "2.5.4",
  "description": "Skills CRUD, HyperSkill format, Svelte 5 stores",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "svelte": "./src/index.ts",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./canvas": {
      "svelte": "./src/canvas.ts",
      "import": "./src/canvas.ts"
    },
    "./canvas-vanilla": {
      "import": "./src/canvas-vanilla.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build": "svelte-package -i src"
  },
  "dependencies": {
    "hyperskills": "^0.1.4"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
