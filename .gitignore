# Dependencies
node_modules/

# Build outputs
dist/
build/
.svelte-kit/

# Deploy fingerprint state (skip rebuild when sources unchanged)
.deploy-state/

# Deploy ETA cache (timings history) and script backups
.deploy-cache/
*.back

# Environment
.env
.env.*
!.env.example

# Healthcheck credentials (basic auth for deploy.sh)
.netrc

# Logs
*.log
npm-debug.log*
logs/

# Editor
.DS_Store
.vscode/
.idea/

# TypeScript incremental build cache
*.tsbuildinfo

# Playwright test output
test-results/
playwright-report/

# TypeScript declaration files (build artifacts in src/)
packages/core/src/*.d.ts

# Astro cache
docs/starlight/.astro/

