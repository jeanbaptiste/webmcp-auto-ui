---
// ServerSelector — checkboxes to toggle widget server packs
---

<div class="server-selector" id="server-selector">
  <h3 class="selector-title">Widget Servers</h3>
  <div class="checkbox-list" id="server-checkboxes">
    <!-- Populated by client script -->
  </div>
  <div class="server-stats" id="server-stats"></div>
</div>

<script>
  import { servers, type ServerEntry } from '../lib/stores';

  const container = document.getElementById('server-checkboxes')!;
  const statsEl = document.getElementById('server-stats')!;

  function render(entries: ServerEntry[]) {
    container.innerHTML = '';
    let totalWidgets = 0;

    for (const entry of entries) {
      const label = document.createElement('label');
      label.className = 'checkbox-item';

      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.checked = entry.enabled;
      cb.className = 'checkbox-input';
      cb.addEventListener('change', () => {
        servers.update(list =>
          list.map(s => s.key === entry.key ? { ...s, enabled: cb.checked } : s)
        );
      });

      const span = document.createElement('span');
      span.className = 'checkbox-label';
      span.textContent = entry.label;

      label.appendChild(cb);
      label.appendChild(span);
      container.appendChild(label);

      if (entry.enabled) {
        const match = entry.label.match(/\((\d+)/);
        if (match) totalWidgets += parseInt(match[1], 10);
      }
    }

    statsEl.textContent = `${entries.filter(s => s.enabled).length} servers active, ${totalWidgets} widgets`;
  }

  servers.subscribe(render);
</script>

<style>
  .server-selector {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }

  .selector-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text2);
    margin-bottom: 8px;
  }

  .checkbox-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  :global(.checkbox-item) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 8px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s;
  }

  :global(.checkbox-item:hover) {
    background: var(--surface2);
  }

  :global(.checkbox-input) {
    width: 14px;
    height: 14px;
    accent-color: var(--accent);
    cursor: pointer;
  }

  :global(.checkbox-label) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text1);
  }

  .server-stats {
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text2);
  }
</style>
