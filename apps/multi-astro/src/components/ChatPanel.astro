---
// ChatPanel — input + messages display
---

<div class="chat-panel" id="chat-panel">
  <div class="messages-area" id="messages-area">
    <div class="welcome-msg">
      <span class="welcome-icon">*</span>
      <span>Multi-server WebMCP demo. Select servers, then ask for a visualization.</span>
    </div>
  </div>

  <div class="progress-bar" id="agent-progress" style="display: none;">
    <span class="progress-dot"></span>
    <span class="progress-text" id="progress-text">Generating...</span>
  </div>

  <div class="input-row">
    <input
      type="text"
      id="chat-input"
      class="chat-input"
      placeholder="Ask for a visualization..."
      autocomplete="off"
    />
    <button id="chat-send" class="send-btn">Send</button>
    <button id="chat-stop" class="stop-btn" style="display: none;">Stop</button>
  </div>
</div>

<script>
  import { messages, generating, agentProgress, type ChatMsg } from '../lib/stores';
  import { sendMessage } from '../lib/agent';

  const messagesArea = document.getElementById('messages-area')!;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('chat-send')!;
  const stopBtn = document.getElementById('chat-stop')!;
  const progressBar = document.getElementById('agent-progress')!;
  const progressText = document.getElementById('progress-text')!;

  function renderMessages(msgs: ChatMsg[]) {
    // Keep the welcome message if no messages
    if (msgs.length === 0) return;

    // Clear and re-render
    messagesArea.innerHTML = '';
    for (const msg of msgs) {
      const bubble = document.createElement('div');
      bubble.className = `msg msg-${msg.role}`;

      const roleSpan = document.createElement('span');
      roleSpan.className = 'msg-role';
      roleSpan.textContent = msg.role === 'user' ? 'You' : msg.role === 'assistant' ? 'AI' : 'Sys';

      const contentSpan = document.createElement('span');
      contentSpan.className = 'msg-content';
      contentSpan.textContent = msg.content;

      bubble.appendChild(roleSpan);
      bubble.appendChild(contentSpan);
      messagesArea.appendChild(bubble);
    }

    messagesArea.scrollTop = messagesArea.scrollHeight;
  }

  function handleSend() {
    const text = chatInput.value.trim();
    if (!text) return;
    chatInput.value = '';
    sendMessage(text);
  }

  sendBtn.addEventListener('click', handleSend);
  chatInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  });

  messages.subscribe(renderMessages);

  generating.subscribe(active => {
    chatInput.disabled = active;
    sendBtn.style.display = active ? 'none' : '';
    stopBtn.style.display = active ? '' : 'none';
    progressBar.style.display = active ? 'flex' : 'none';
  });

  agentProgress.subscribe(p => {
    const parts: string[] = [];
    if (p.elapsed > 0) parts.push(`${p.elapsed}s`);
    if (p.toolCalls > 0) parts.push(`${p.toolCalls} tools`);
    if (p.lastTool) parts.push(p.lastTool);
    progressText.textContent = parts.length > 0 ? parts.join(' | ') : 'Generating...';
  });
</script>

<style>
  .chat-panel {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
  }

  .messages-area {
    flex: 1;
    overflow-y: auto;
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .welcome-msg {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px;
    background: var(--surface2);
    border-radius: 8px;
    font-size: 12px;
    color: var(--text2);
  }

  .welcome-icon {
    font-size: 18px;
    color: var(--accent);
  }

  :global(.msg) {
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.5;
    max-width: 90%;
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  :global(.msg-user) {
    background: var(--accent);
    color: var(--bg);
    align-self: flex-end;
  }

  :global(.msg-assistant) {
    background: var(--surface2);
    color: var(--text1);
    align-self: flex-start;
  }

  :global(.msg-system) {
    background: var(--error);
    color: white;
    align-self: center;
    font-size: 11px;
    opacity: 0.8;
  }

  :global(.msg-role) {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    opacity: 0.6;
    flex-shrink: 0;
    padding-top: 2px;
  }

  :global(.msg-content) {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .progress-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .progress-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .progress-text {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text2);
  }

  .input-row {
    display: flex;
    gap: 6px;
    padding: 12px 16px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .chat-input {
    flex: 1;
    padding: 10px 14px;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 10px;
    color: var(--text1);
    font-family: var(--font-mono);
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
  }

  .chat-input:focus {
    border-color: var(--accent);
  }

  .chat-input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .chat-input::placeholder {
    color: var(--text2);
    opacity: 0.5;
  }

  .send-btn {
    padding: 10px 18px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .send-btn:hover {
    opacity: 0.85;
  }

  .stop-btn {
    padding: 10px 18px;
    background: var(--accent2);
    color: white;
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .stop-btn:hover {
    opacity: 0.85;
  }
</style>
