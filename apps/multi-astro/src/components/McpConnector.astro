---
// McpConnector — URL input to connect an MCP data server
---

<div class="mcp-connector" id="mcp-connector">
  <h3 class="connector-title">MCP Server</h3>
  <div class="connector-row">
    <input
      type="text"
      id="mcp-url-input"
      class="url-input"
      placeholder="wss://mcp.example.com/sse"
    />
    <button id="mcp-connect-btn" class="connect-btn">Connect</button>
  </div>
  <div class="connector-status" id="mcp-status">Not connected</div>
</div>

<script>
  import { McpClient } from '@webmcp-auto-ui/core';
  import { mcpUrl, mcpConnected, mcpName } from '../lib/stores';

  const urlInput = document.getElementById('mcp-url-input') as HTMLInputElement;
  const connectBtn = document.getElementById('mcp-connect-btn')!;
  const statusEl = document.getElementById('mcp-status')!;

  let client: McpClient | null = null;

  connectBtn.addEventListener('click', async () => {
    const url = urlInput.value.trim();
    if (!url) return;

    statusEl.textContent = 'Connecting...';
    statusEl.className = 'connector-status connecting';
    connectBtn.textContent = '...';

    try {
      client = new McpClient(url);
      await client.connect();
      const info = client.getServerInfo();
      mcpUrl.set(url);
      mcpConnected.set(true);
      mcpName.set(info?.name ?? url);
      statusEl.textContent = `Connected to ${info?.name ?? url}`;
      statusEl.className = 'connector-status connected';
      connectBtn.textContent = 'Disconnect';
    } catch (e) {
      const msg = e instanceof Error ? e.message : String(e);
      statusEl.textContent = `Error: ${msg}`;
      statusEl.className = 'connector-status error';
      connectBtn.textContent = 'Connect';
    }
  });

  mcpConnected.subscribe(connected => {
    if (!connected && client) {
      client = null;
      statusEl.textContent = 'Not connected';
      statusEl.className = 'connector-status';
      connectBtn.textContent = 'Connect';
    }
  });
</script>

<style>
  .mcp-connector {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }

  .connector-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text2);
    margin-bottom: 8px;
  }

  .connector-row {
    display: flex;
    gap: 6px;
  }

  .url-input {
    flex: 1;
    padding: 6px 10px;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 6px;
    color: var(--text1);
    font-family: var(--font-mono);
    font-size: 12px;
    outline: none;
    transition: border-color 0.15s;
  }

  .url-input:focus {
    border-color: var(--accent);
  }

  .url-input::placeholder {
    color: var(--text2);
    opacity: 0.5;
  }

  .connect-btn {
    padding: 6px 14px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .connect-btn:hover {
    opacity: 0.85;
  }

  .connector-status {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text2);
  }

  .connector-status.connected {
    color: var(--teal);
  }

  .connector-status.connecting {
    color: var(--accent);
  }

  .connector-status.error {
    color: var(--error);
  }
</style>
