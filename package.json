{
  "name": "webmcp-auto-ui",
  "private": true,
  "version": "2.2.0",
  "workspaces": [
    "packages/core",
    "packages/ui",
    "packages/agent",
    "packages/sdk",
    "packages/widgets-vanilla",
    "packages/widgets-d3",
    "packages/widgets-threejs",
    "packages/widgets-canvas2d",
    "packages/widgets-leaflet",
    "packages/widgets-plotly",
    "packages/widgets-mermaid",
    "packages/widgets-mapbox",
    "packages/widgets-mui",
    "apps/home",
    "apps/flex2",
    "apps/viewer2",
    "apps/todo2",
    "apps/showcase2",
    "apps/recipes",
    "apps/multi-astro",
    "apps/multi-svelte",
    "apps/multi-react",
    "apps/multi-vue",
    "apps/multi-webcomponents",
    "docs-site"
  ],
  "scripts": {
    "dev": "concurrently -n home,flex2,viewer2,showcase2,todo2 -c blue,magenta,yellow,green,red \"npm -w apps/home run dev\" \"npm -w apps/flex2 run dev\" \"npm -w apps/viewer2 run dev\" \"npm -w apps/showcase2 run dev\" \"npm -w apps/todo2 run dev\"",
    "dev:home": "npm -w apps/home run dev",
    "dev:flex2": "npm -w apps/flex2 run dev",
    "dev:viewer2": "npm -w apps/viewer2 run dev",
    "dev:showcase2": "npm -w apps/showcase2 run dev",
    "dev:todo2": "npm -w apps/todo2 run dev",
    "dev:recipes": "npm -w apps/recipes run dev",
    "build": "npm -w apps/home run build && npm -w apps/flex2 run build && npm -w apps/viewer2 run build && npm -w apps/showcase2 run build && npm -w apps/todo2 run build && npm -w apps/recipes run build",
    "check": "npm -w packages/ui run check && npm -w packages/sdk run check",
    "deploy": "./scripts/deploy.sh",
    "docs:sync": "node scripts/sync-docs.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:facts": "npx tsx scripts/extract-facts.ts",
    "docs:diagrams": "npx tsx scripts/generate-diagrams.ts",
    "docs:svg": "npx tsx scripts/render-diagrams.ts",
    "docs:prose": "npx tsx scripts/generate-prose.ts",
    "docs:pipeline": "npx tsx scripts/generate-docs.pipeline.ts",
    "docs:generate": "bash scripts/generate-docs.sh"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@mediapipe/tasks-genai": "^0.10.27",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.0",
    "ts-morph": "^27.0.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "@astrojs/sitemap": "3.3.0"
  }
}
