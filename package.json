{
  "name": "webmcp-auto-ui",
  "private": true,
  "version": "2.5.13",
  "workspaces": [
    "packages/core",
    "packages/ui",
    "packages/agent",
    "packages/sdk",
    "apps/home",
    "apps/flex",
    "apps/viewer",
    "apps/todo",
    "apps/showcase",
    "apps/recipes",
    "apps/boilerplate",
    "docs-site"
  ],
  "scripts": {
    "dev": "concurrently -n home,flex,viewer,showcase,todo -c blue,magenta,yellow,green,red \"npm -w apps/home run dev\" \"npm -w apps/flex run dev\" \"npm -w apps/viewer run dev\" \"npm -w apps/showcase run dev\" \"npm -w apps/todo run dev\"",
    "dev:home": "npm -w apps/home run dev",
    "dev:flex": "npm -w apps/flex run dev",
    "dev:viewer": "npm -w apps/viewer run dev",
    "dev:showcase": "npm -w apps/showcase run dev",
    "dev:todo": "npm -w apps/todo run dev",
    "dev:recipes": "npm -w apps/recipes run dev",
    "build": "npm -w apps/home run build && npm -w apps/flex run build && npm -w apps/viewer run build && npm -w apps/showcase run build && npm -w apps/todo run build && npm -w apps/recipes run build",
    "check": "npm -w packages/ui run check && npm -w packages/sdk run check",
    "deploy": "./scripts/deploy.sh",
    "docs:sync": "node scripts/sync-docs.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:facts": "npx tsx scripts/extract-facts.ts",
    "docs:diagrams": "npx tsx scripts/generate-diagrams.ts",
    "docs:svg": "npx tsx scripts/render-diagrams.ts",
    "docs:prose": "npx tsx scripts/generate-prose.ts",
    "docs:pipeline": "npx tsx scripts/generate-docs.pipeline.ts",
    "docs:generate": "bash scripts/generate-docs.sh"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@mediapipe/tasks-genai": "^0.10.27",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.0",
    "ts-morph": "^27.0.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "@astrojs/sitemap": "3.3.0"
  }
}
